{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/login",
      "dest": "api/login.php"
    },
    {
      "src": "/register",
      "dest": "api/register.php"
    },
    {
      "src": "/dashboard",
      "dest": "api/dashboard.php"
    },
    {
      "src": "/logout",
      "dest": "api/logout.php"
    },
    {
      "src": "/",
      "dest": "api/login.php"
    }
  ]
}